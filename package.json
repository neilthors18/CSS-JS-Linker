{
  "name": "css-js-linker",
  "displayName": "CSS/JS Linker",
  "description": "Navigate from HTML class/id attributes to their CSS definitions and JS references in linked files (supports Django {% static %} paths).",
  "version": "0.1.3",
  "publisher": "PrimeTek",
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "html",
    "css",
    "javascript",
    "django",
    "go to definition",
    "hover",
    "class",
    "id"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:django-html",
    "onLanguage:php",
    "onLanguage:jinja",
    "onLanguage:jinja2"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
